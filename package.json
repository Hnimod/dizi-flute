{
  "name": "dizi-flute",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "vite & VITE_PID=$!; trap 'kill $VITE_PID 2>/dev/null' EXIT; sleep 2 && npx wrangler pages dev --proxy=5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy": "npm run build && npx wrangler pages deploy dist/ --project-name dizi-flute",
    "db:migrate": "npx wrangler d1 execute dizi-flute --file=./db/migrations/001-init.sql",
    "db:seed": "npx wrangler d1 execute dizi-flute --file=./db/seed.sql",
    "db:generate-seed": "npx tsx --tsconfig tsconfig.app.json db/generate-seed.ts > db/seed.sql"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-router": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250313.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "wrangler": "^4.14.0"
  }
}
