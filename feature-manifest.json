{
  "features": {
    "theme": {
      "path": "src/features/theme",
      "description": "Dark/light mode toggle — Zustand store with persist middleware",
      "routes": [],
      "exports": ["ThemeToggle", "useThemeStore"],
      "dependsOn": ["shared"],
      "crossFeatureDeps": []
    },
    "progress-tracking": {
      "path": "src/features/progress-tracking",
      "description": "Completion and favorites tracking — Zustand store with persist middleware",
      "routes": [],
      "exports": ["useProgressStore"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": []
    },
    "song-library": {
      "path": "src/features/song-library",
      "description": "Home page: browse songs by level, search, favorites, song detail with technique links",
      "routes": ["/", "/song/:songId"],
      "exports": ["SongLibraryPage", "SongDetailPage", "useSongLibraryStore"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": ["progress-tracking", "lesson-viewer", "auth", "admin"],
      "status": "done"
    },
    "technique-library": {
      "path": "src/features/technique-library",
      "description": "Browse techniques by category, technique detail with exercises and related songs",
      "routes": ["/techniques", "/techniques/:techniqueId"],
      "exports": ["TechniqueLibraryPage", "TechniqueDetailPage"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": ["progress-tracking", "lesson-viewer"],
      "status": "done"
    },
    "reference-library": {
      "path": "src/features/reference-library",
      "description": "Knowledge hub: fingering charts, jianpu guide, dizi theory",
      "routes": ["/knowledge", "/knowledge/:slug"],
      "exports": ["ReferencePage", "ReferenceDetailPage"],
      "dependsOn": ["shared", "data"]
    },
    "lesson-viewer": {
      "path": "src/features/lesson-viewer",
      "description": "PracticeView for full-screen song/exercise practice, TempoGuide for jianpu display",
      "routes": [],
      "exports": ["PracticeView"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": ["progress-tracking"]
    },
    "practice-timer": {
      "path": "src/features/practice-timer",
      "description": "Guided practice sessions with timer",
      "routes": ["/practice"],
      "exports": ["PracticePage", "usePracticeStore"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": [],
      "status": "done"
    },
    "auth": {
      "path": "src/features/auth",
      "description": "Two-tier auth: email-only identify for users, email+password for admin. Syncs progress to DB.",
      "routes": [],
      "exports": ["useAuthStore", "IdentifyPrompt", "AdminLoginPage", "SyncProvider"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": ["progress-tracking", "practice-timer", "song-library"],
      "status": "done"
    },
    "admin": {
      "path": "src/features/admin",
      "description": "Inline song/exercise editors for admin content management",
      "routes": [],
      "exports": ["SongEditor", "ExerciseEditor"],
      "dependsOn": ["shared", "data"],
      "crossFeatureDeps": ["auth"],
      "status": "done"
    }
  }
}
