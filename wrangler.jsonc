{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "dizi-flute",
  "compatibility_date": "2025-01-01",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "dizi-flute",
      // Replace with actual ID after running: npx wrangler d1 create dizi-flute
      "database_id": "REPLACE_ME"
    }
  ]
}
